# .env.example
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real values.
# ─────────────────────────────────────────────────────────────────

# Backend API base URL
#
# Development:
#   Leave this blank — Vite's proxy (vite.config.js) automatically
#   forwards all /api/* requests to localhost:8000.
#   You do NOT need to set this during local development.
#
# Production:
#   Set this to wherever your FastAPI backend is hosted.
#   Example: https://stegoanalyzer-api.onrender.com
#
VITE_API_URL=